{
  "name": "temp-private-2110-new-be-for-fe",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "service2110"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "service2110:dev": "npm run start:dev -w service2110",
    "service2110:checks": "npm run checks -w service2110",
    "service2110:typecheck": "npm run typecheck -w service2110",
    "kill:port": "node scripts/kill-port.js",
    "kill:3000": "node scripts/kill-port.js 3000",
    "kill:all": "npm run kill:3000",
    "kill:node": "taskkill /F /IM node.exe 2>nul || echo \"✅ No node processes running\"",
    "predev": "npm run kill:3000",
    "docs:generate": "node scripts/generate-swagger-html.js",
    "docs:preview": "npm run docs:generate && echo \"📄 Open docs/public/index.html in your browser\"",
    "ci:lint": "npm run lint -w service2110",
    "ci:build": "npm run build -w service2110",
    "ci:check": "npm run ci:lint && npm run ci:build",
    "ai-tasks:run": "node scripts/ai-tasks-runner/runner.js",
    "ai-tasks:dry-run": "node scripts/ai-tasks-runner/runner.js --dry-run"
  },
  "description": "Monorepo with Backend project",
  "devDependencies": {
    "dotenv": "17.2.3",
    "patch-package": "^8.0.1"
  }
}
